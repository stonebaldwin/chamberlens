# ─────────────────────────────────────────────────────────────────────────────
# Public-Data Monorepo — environment variables
# Copy to .env and fill in. For the Cloudflare Workers runtime, mirror secrets
# into apps/web/.dev.vars (local) or `wrangler secret put` (deployed).
# Phase 0 only needs DATABASE_URL.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Neon Postgres) ───────────────────────────── [required: Phase 0+]
# Pooled connection string from the Neon dashboard.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ── Cloudflare (deploy) ─────────────────────── [Phase 0 deploy / Phase 6 cron]
# Used by Wrangler for deploys. `wrangler login` also works for local/interactive.
# CLOUDFLARE_ACCOUNT_ID=""
# CLOUDFLARE_API_TOKEN=""

# ── Auth (Better Auth) ──────────────────────────────────────────── [Phase 4]
# BETTER_AUTH_SECRET=""            # openssl rand -base64 32 (required for auth)
# BETTER_AUTH_URL="http://localhost:3007"   # must match the dev server origin

# ── Email (Resend) ──────────────────────── [Phase 4 magic links / Phase 6 alerts]
# RESEND_API_KEY=""
# EMAIL_FROM="ChamberLens <alerts@chamberlens.com>"
# OPERATOR_EMAIL=""                # ingestion-health alerts are sent here

# ── Stripe (billing) ────────────────────────────────────────────── [Phase 5]
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# STRIPE_PRICE_PRO_MONTHLY=""
# STRIPE_PRICE_PRO_ANNUAL=""
# STRIPE_PRICE_BUSINESS_MONTHLY=""
# STRIPE_PRICE_BUSINESS_ANNUAL=""
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Speech-to-text (swappable provider) ───────────────── [Phase 1 / Phase 6]
# STT_PROVIDER="deepgram"          # "deepgram" | "assemblyai"
# DEEPGRAM_API_KEY=""
# ASSEMBLYAI_API_KEY=""
# STT_MONTHLY_BUDGET_USD="50"      # hard spend cap (budget guard, Phase 1.4)

# ── Legistar (ingestion) ───────────────────────────────── [Phase 1 / Phase 6]
# The Legistar Web API needs no global key. Some clients require a per-client
# token, configured per jurisdiction in platform_configs — not a global secret.

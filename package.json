{
  "name": "public-data-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Public-data holding company monorepo — reusable ingestion Core, shared packages, and product apps (ChamberLens first).",
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter web dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "pnpm --filter @repo/db db:generate",
    "db:migrate": "pnpm --filter @repo/db db:migrate",
    "db:studio": "pnpm --filter @repo/db db:studio",
    "db:seed": "pnpm --filter web seed",
    "clean": "pnpm -r exec rm -rf dist .next .open-next .wrangler .turbo *.tsbuildinfo"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@eslint/js": "^9",
    "@types/node": "22.19.19",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "prettier": "3.8.3",
    "typescript": "5.9.3",
    "typescript-eslint": "^8"
  }
}
